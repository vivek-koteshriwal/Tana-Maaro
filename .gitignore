# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.swp
*.swo
*.log

# npm cache
.npm_cache/

# mobile build artifacts
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies

# logs
dev-output.log
firebase-debug.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# editor / assistant state
.vscode/
.idea/
.claude/
mobile/.vscode/
mobile/.idea/
mobile/.claude/

# mobile generated files
mobile/android/.gradle/
mobile/android/app/.cxx/
mobile/android/local.properties
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/flutter_export_environment.sh

# local uploaded media
public/uploads/

# typescript
*.tsbuildinfo
next-env.d.ts
