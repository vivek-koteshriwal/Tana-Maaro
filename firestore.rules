rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSelf(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isSelf(userId)
        || (
          signedIn()
          && changedOnly(['followerCount'])
          && request.resource.data.followerCount is int
          && resource.data.followerCount is int
          && (
            request.resource.data.followerCount == resource.data.followerCount + 1
            || request.resource.data.followerCount == resource.data.followerCount - 1
          )
        );
      allow delete: if isSelf(userId);

      match /hiddenPosts/{postId} {
        allow read, create, delete: if isSelf(userId);
        allow update: if false;
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Public read is required for the current phone-login flow.
    // If you want this private, move phone lookup to a backend/Cloud Function.
    match /phones/{phone} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/phones/$(phone));
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || (
          changedOnly(['likes', 'dislikes', 'likedBy', 'dislikedBy', 'comments', 'shares'])
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.userName == resource.data.userName
          && request.resource.data.userHandle == resource.data.userHandle
          && request.resource.data.userAvatar == resource.data.userAvatar
          && request.resource.data.content == resource.data.content
          && request.resource.data.image == resource.data.image
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.type == resource.data.type
          && request.resource.data.battleId == resource.data.battleId
        )
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Used by the repo-level web code.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    match /battles/{battleId} {
      allow read: if true;
      allow write: if false;
    }

    // Partnership applications. Owners can read their own submitted doc.
    match /partnerships/{id} {
      allow create: if signedIn() && request.resource.data.keys().hasOnly([
        'name',
        'company',
        'email',
        'phone',
        'message',
        'timestamp',
        'status',
        'userId'
      ]) && request.resource.data.status == 'pending'
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.type == 'post';
      allow read: if signedIn() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    match /registrations/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
